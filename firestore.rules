rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: is the requesting user an admin? ────────────────────
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── User document (profile + zone calibration) ──────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();

      // ── Races ──────────────────────────────────────────────────────
      match /races/{raceId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if isAdmin();
      }

      // ── Training plans ─────────────────────────────────────────────
      match /training_plans/{planId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if isAdmin();
      }

      // ── Workouts ───────────────────────────────────────────────────
      match /workouts/{workoutId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if isAdmin();
      }

      // ── Training plan versions ─────────────────────────────────────
      match /training_plan_versions/{versionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if isAdmin();
      }

      // ── Strava tokens (write only via Cloud Function) ──────────────
      match /strava_tokens/{tokenId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // ── Strava activities (write only via Cloud Function) ──────────
      match /strava_activities/{activityId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow read: if isAdmin();
        allow write: if false;
      }
    }

    // ── Strava athlete index (internal — only Cloud Functions write) ─
    match /strava_athlete_index/{athleteId} {
      allow read, write: if false;
    }

    // ── Incidents ───────────────────────────────────────────────────
    match /incidents/{incidentId} {
      // User: create their own, read/update their own (only messages + updated_at)
      allow create: if request.auth != null &&
        request.resource.data.user_uid == request.auth.uid;
      allow read: if request.auth != null &&
        resource.data.user_uid == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.user_uid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['messages', 'updated_at']);
      // Admin: full access
      allow read, write: if isAdmin();
    }
  }
}
