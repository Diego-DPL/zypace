rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Adjuntos de incidencias: cada usuario escribe en su carpeta,
    // cualquier usuario autenticado puede leer (las URLs se guardan en Firestore)
    match /incident-attachments/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024   // máx 10 MB
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
