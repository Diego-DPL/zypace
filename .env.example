# ── Firebase (frontend) ──────────────────────────────────────
# Firebase Console → Configuración del proyecto → Tus apps → SDK snippet
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Strava OAuth ─────────────────────────────────────────────
VITE_STRAVA_CLIENT_ID=your_strava_client_id
# STRAVA_CLIENT_SECRET → firebase functions:secrets:set STRAVA_CLIENT_SECRET

# ── Analytics ─────────────────────────────────────────────────
# GA4: Google Analytics → Admin → Data Streams → Measurement ID (G-XXXXXXXXXX)
VITE_GA4_ID=G-XXXXXXXXXX

# ── Cloud Function secrets (NO poner aquí, usar Firebase Secrets) ──
# firebase functions:secrets:set STRAVA_CLIENT_ID
# firebase functions:secrets:set STRAVA_CLIENT_SECRET
# firebase functions:secrets:set OPENAI_API_KEY
# firebase functions:secrets:set OPENAI_MODEL   (ej: gpt-4o)
